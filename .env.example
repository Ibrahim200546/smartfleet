# Frontend -> backend REST API
NEXT_PUBLIC_API_URL=http://localhost:8000

# Backend API
SMARTFLEET_DATABASE_URL=sqlite+aiosqlite:///./smartfleet.db
SMARTFLEET_API_HOST=0.0.0.0
SMARTFLEET_API_PORT=8000
SMARTFLEET_CORS_ORIGINS=http://localhost:3000,https://your-project.vercel.app

# Teltonika TCP ingest server; deploy this outside Vercel on a host with TCP ports.
SMARTFLEET_TCP_HOST=0.0.0.0
SMARTFLEET_TCP_PORT=5027
SMARTFLEET_AUTO_REGISTER_TRACKERS=true
